{
  "defaults": {
    "timeout": 30000,
    "wait": 2000,
    "standard": "WCAG2AA",
    "chromeLaunchConfig": {
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-dev-shm-usage",
        "--disable-gpu"
      ],
      "ignoreHTTPSErrors": true,
      "headless": "new",
      "executablePath": "chromium"
    },
    "viewport": {
      "width": 1280,
      "height": 1024
    },
    "ignore": [
      "WCAG2AA.Principle1.Guideline1_4.1_4_3.G18.Fail"
    ],
    "runners": ["axe", "htmlcs"]
  },
  "urls": [
    {
      "url": "http://localhost:5173",
      "screenCapture": "./reports/home.png",
      "timeout": 60000
    },
    {
      "url": "http://localhost:5173/manage",
      "screenCapture": "./reports/manage.png",
      "timeout": 60000
    },
    {
      "url": "http://localhost:5173/monitor",
      "screenCapture": "./reports/monitor.png",
      "timeout": 60000
    },
    {
      "url": "http://localhost:5173/configure",
      "screenCapture": "./reports/configure.png",
      "timeout": 60000
    },
    {
      "url": "http://localhost:5173/profile",
      "screenCapture": "./reports/profile.png",
      "timeout": 60000
    },
    {
      "url": "http://localhost:5173/support",
      "screenCapture": "./reports/support.png",
      "timeout": 60000
    }
  ]
}